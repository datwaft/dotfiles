{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "rosepine",
  "keybinds": {
    "input_line_home": "home",
    "input_line_end": "end",
    "input_buffer_home": "none",
    "input_buffer_end": "none",
    "messages_first": "ctrl+g",
    "messages_last": "ctrl+alt+g",
    "input_delete_to_line_start": "super+backspace,super+delete",
  },
}

