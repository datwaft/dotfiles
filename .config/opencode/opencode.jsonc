{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "lsp": "allow",
    "bash": {
      // Jira CLI
      "jira*": "ask",
      "jira help*": "allow",
      "jira*--help*": "allow",
      "jira version*": "allow",
      "jira me*": "allow",
      "jira serverinfo*": "allow",
      "jira project list*": "allow",
      "jira board list*": "allow",
      "jira release list*": "allow",
      "jira issue list*": "allow",
      "jira issue view*": "allow",
      "jira epic list*": "allow",
      "jira sprint list*": "allow",
      "jira open* -n*": "allow",
      // Atlassian CLI
      "acli*": "ask",
      "acli help*": "allow",
      "acli*--help*": "allow",
      "acli jira board get*": "allow",
      "acli jira board list-projects*": "allow",
      "acli jira board list-sprints*": "allow",
      "acli jira board search*": "allow",
      "acli jira dashboard search*": "allow",
      "acli jira filter get*": "allow",
      "acli jira filter get-columns*": "allow",
      "acli jira filter list*": "allow",
      "acli jira filter search*": "allow",
      "acli jira project list*": "allow",
      "acli jira project view*": "allow",
      "acli jira sprint list-workitems*": "allow",
      "acli jira sprint view*": "allow",
      "acli jira workitem attachment list*": "allow",
      "acli jira workitem comment list*": "allow",
      "acli jira workitem comment visibility*": "allow",
      "acli jira workitem link list*": "allow",
      "acli jira workitem link type*": "allow",
      "acli jira workitem view*": "allow",
      "acli jira workitem search*": "allow",
      "acli jira workitem watcher list*": "allow",
      "acli confluence blog list*": "allow",
      "acli confluence blog view*": "allow",
      "acli confluence page view*": "allow",
      "acli confluence space list*": "allow",
      "acli confluence space view*": "allow",
      // Jujutsu (jj-vcs)
      "jj*": "ask",
      "jj*--help*": "allow",
      "jj help*": "allow",
      "jj status*": "allow",
      "jj st*": "allow",
      "jj log*": "allow",
      "jj diff*": "allow",
      "jj show*": "allow",
      "jj interdiff*": "allow",
      "jj version*": "allow",
      "jj root*": "allow",
      "jj file list*": "allow",
      "jj file annotate*": "allow",
      "jj file show*": "allow",
      "jj file search*": "allow",
      "jj operation log*": "allow",
      "jj op log*": "allow",
      "jj operation show*": "allow",
      "jj op show*": "allow",
      "jj evolution-log*": "allow",
      "jj evolog*": "allow",
      "jj bookmark list*": "allow",
      "jj bookmark l*": "allow",
      "jj b list*": "allow",
      "jj b l*": "allow",
      "jj tag list*": "allow",
      "jj tag l*": "allow",
      "jj config list*": "allow",
      "jj config l*": "allow",
      "jj config get*": "allow",
      "jj config g*": "allow",
      "jj config path*": "allow",
      "jj config p*": "allow",
      "jj workspace list*": "allow",
      "jj workspace root*": "allow",
      "jj git remote list*": "allow",
      "jj git root*": "allow",
      "jj git fetch*": "allow",
      // Git
      "git*": "ask",
      "git*--help*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch -l*": "allow",
      "git branch --list*": "allow",
      "git branch -a*": "allow",
      "git branch -r*": "allow",
      "git branch -v*": "allow",
      "git branch -vv*": "allow",
      "git tag -l*": "allow",
      "git tag --list*": "allow",
      "git remote -v*": "allow",
      "git remote show*": "allow",
      "git config --get*": "allow",
      "git config --list*": "allow",
      "git config -l*": "allow",
      "git rev-parse*": "allow",
      "git describe*": "allow",
      "git ls-files*": "allow",
      "git ls-tree*": "allow",
      "git blame*": "allow",
      "git shortlog*": "allow",
      "git stash list*": "allow",
      "git worktree list*": "allow",
      "git fetch*": "allow",
      "git cat-file*": "allow",
      "git for-each-ref*": "allow",
      "git reflog*": "allow",
      "git merge-base*": "allow",
      "git version*": "allow",
    },
  },
}
